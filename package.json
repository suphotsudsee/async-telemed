{
  "name": "async-telemed",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend/node-api",
    "frontend-patient",
    "frontend-doctor",
    "frontend-admin"
  ],
  "scripts": {
    "dev:patient": "npm --workspace frontend-patient run dev",
    "dev:doctor": "npm --workspace frontend-doctor run dev",
    "dev:admin": "npm --workspace frontend-admin run dev",
    "dev:node-api": "npm --workspace backend/node-api run dev",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces"
  }
}
