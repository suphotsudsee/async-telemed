# Database
DATABASE_URL=postgresql://telemed:telemed@localhost:5432/telemed

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production

# Encryption (32 bytes hex = 64 characters)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# OTP Configuration
OTP_MODE=demo
# SMS_PROVIDER_URL=https://sms-provider.example.com/send
# SMS_PROVIDER_KEY=your-sms-api-key

# Storage Configuration
STORAGE_PROVIDER=local
# For S3/MinIO:
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=telemed-uploads
# STORAGE_REGION=ap-southeast-1
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key
# STORAGE_ENDPOINT=https://s3.amazonaws.com

# LINE Integration
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ID=your-line-channel-id
LINE_LIFF_ID=your-liff-id

# API URL (for presigned URLs)
API_URL=http://localhost:8080

# Node Environment
NODE_ENV=development
PORT=8080
